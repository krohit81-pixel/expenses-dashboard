# Public — safe to expose to the browser. See src/lib/env/public.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. See src/lib/env/server.ts.
# Bypasses Row Level Security. Required for src/lib/supabase/service.ts.
SUPABASE_SERVICE_ROLE_KEY=

# There is no visible sign-in screen. Every visitor is automatically
# signed in as this single fixed account (see src/middleware.ts) — this
# app has no login barrier beyond "knows the URL," by explicit choice.
# Use a real email address (any address works, it never receives mail —
# email confirmation is set programmatically) and a strong, unique
# password. The first request after deploy creates this Supabase Auth
# user automatically if it doesn't exist yet.
APP_OWNER_EMAIL=
APP_OWNER_PASSWORD=
