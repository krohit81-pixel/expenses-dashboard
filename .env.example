# Public — safe to expose to the browser. See src/lib/env/public.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. See src/lib/env/server.ts.
# Bypasses Row Level Security. Required for src/lib/supabase/service.ts,
# which is now the ONLY data-access client the app uses (see
# src/lib/owner.ts) — there is no session-based auth anymore.
SUPABASE_SERVICE_ROLE_KEY=

# There is no visible sign-in screen and no session — every request runs
# as this single fixed account (see src/middleware.ts, src/lib/owner.ts).
# This is NOT a login credential; it's just the UUID of a Supabase Auth
# user created once via `npm run bootstrap:owner` (see INSTALL.md). Every
# row in the database belongs to this ID.
APP_OWNER_USER_ID=
