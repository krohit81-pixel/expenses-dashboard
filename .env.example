# Public — safe to expose to the browser. See src/lib/env/public.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. See src/lib/env/server.ts.
# Bypasses Row Level Security. Required for src/lib/supabase/service.ts,
# which is now the ONLY data-access client the app uses (see
# src/lib/owner.ts) — there is no session-based auth anymore.
SUPABASE_SERVICE_ROLE_KEY=

# There is no visible sign-in screen and no session — every request runs
# as this single fixed account (see src/middleware.ts, src/lib/owner.ts).
# This is NOT a login credential; it's just the UUID of a Supabase Auth
# user created once via `npm run bootstrap:owner` (see INSTALL.md). Every
# row in the database belongs to this ID.
APP_OWNER_USER_ID=

# The access gate — a single shared password for the whole app (not
# Supabase Auth). /calendar stays public; every other page requires this
# once per browser. See src/lib/access-gate.ts.
APP_ACCESS_PASSWORD=
# Signs the access-gate cookie. Generate a random string at least 32
# characters long — don't reuse another secret. e.g.: openssl rand -hex 32
APP_SESSION_SECRET=

# Optional — Intel's auto-generated insight (a short natural-language
# summary of this month's cash flow). The page and its charts work fine
# without either of these; the insight card just shows a "not configured"
# message instead. Set one or the other, not necessarily both — if both
# are set, Anthropic is used. See src/services/IntelService.ts.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Optional — overrides the default Gemini model (gemini-2.5-flash) used
# when GEMINI_API_KEY is set. Only needed if that default is ever deprecated.
GEMINI_MODEL=

# Optional — password for HDFC's Infinia credit card statement PDF (they
# email these encrypted). Without it, the Imports page still loads, it
# just can't decrypt a protected PDF and says so rather than crashing.
# See src/services/StatementImportService.ts.
HDFC_INFINIA_STATEMENT_PASSWORD=

# Optional — same as above, for Axis's own encrypted statement PDFs.
# Covers both card products the axis-horizon-airtel parser handles
# (Horizon and the Airtel co-branded Mastercard) — one shared variable,
# not a per-product one, since Axis uses the same password scheme for
# both. A separate variable from HDFC/ICICI's since each bank's password
# scheme has no reason to match another's. Added in v1.7.0 as
# AXIS_HORIZON_STATEMENT_PASSWORD, renamed in v1.10.0.
AXIS_STATEMENT_PASSWORD=

# Optional — same as above, for ICICI's own encrypted statement PDFs.
# Covers both card products the icici-amazon-rupay parser handles (Amazon
# Pay and RuPay-variant cards) — confirmed to use the same password
# scheme for both, so one shared variable rather than a per-product one.
ICICI_STATEMENT_PASSWORD=
