# Public — safe to expose to the browser. See src/lib/env/public.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. See src/lib/env/server.ts.
# Bypasses Row Level Security. Required for src/lib/supabase/service.ts,
# which is now the ONLY data-access client the app uses (see
# src/lib/owner.ts) — there is no session-based auth anymore.
SUPABASE_SERVICE_ROLE_KEY=

# There is no visible sign-in screen and no session — every request runs
# as this single fixed account (see src/middleware.ts, src/lib/owner.ts).
# This is NOT a login credential; it's just the UUID of a Supabase Auth
# user created once via `npm run bootstrap:owner` (see INSTALL.md). Every
# row in the database belongs to this ID.
APP_OWNER_USER_ID=

# The access gate — a single shared password for the whole app (not
# Supabase Auth). /calendar stays public; every other page requires this
# once per browser. See src/lib/access-gate.ts.
APP_ACCESS_PASSWORD=
# Signs the access-gate cookie. Generate a random string at least 32
# characters long — don't reuse another secret. e.g.: openssl rand -hex 32
APP_SESSION_SECRET=

# Optional — Intel's auto-generated insight (a short natural-language
# summary of this month's cash flow). The page and its charts work fine
# without either of these; the insight card just shows a "not configured"
# message instead. Set one or the other, not necessarily both — if both
# are set, Anthropic is used. See src/services/IntelService.ts.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional — overrides the default OpenAI model (gpt-4o-mini) used when
# OPENAI_API_KEY is set. Only needed if that default is ever deprecated.
OPENAI_MODEL=
